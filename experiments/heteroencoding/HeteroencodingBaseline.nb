Cell[CellGroupData[{

Cell["Heteroencoding", "Title",ExpressionUUID->"d073459d-127b-439c-b315-94de6963b699"],

Cell["Baseline Experiment", "Subtitle",ExpressionUUID->"74e7b6e8-0439-46d3-8fb5-ca078b2a5326"],

Cell["\<\
Testing heteroencoding with a synthetic dataset, consisting of random \
integers from 0 to 9 encoded as random SHRs with population 10. This circuit \
adds 30 random elements and randomly removes a few elements.
The heteroencoder component successfully clusters this data into 10 bins.
\
\>", "Text",ExpressionUUID->"86cc569a-be37-4aff-8a57-73ac76739a7f"],

