Cell[CellGroupData[{

Cell["Analyze prediction score", "Subsection",ExpressionUUID->"43b23ddc-096d-451f-92cd-c27b2a89dbd7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Do", "[", " ", "\n", "\t", 
   RowBox[{
    RowBox[{
     RowBox[{"predictions", " ", "=", " ", 
      RowBox[{"c", " ", "/@", " ", "dataset"}]}], ";", " ", "\n", "\t", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<    iteration = \>\"", ",", " ", "i", ",", " ", "\n", 
       "\t", "\"\<, prediction score = \>\"", ",", " ", 
       RowBox[{"N", "[", 
        RowBox[{"Mean", "@", 
         RowBox[{"Boole", "@", 
          RowBox[{"MapThread", "[", 
           RowBox[{"SameQ", ",", " ", "\n", "\t\t", 
            RowBox[{"{", 
             RowBox[{"dataset", ",", " ", 
              RowBox[{"RotateRight", "[", "predictions", "]"}]}], "}"}]}], 
           "]"}]}]}], "]"}]}], "]"}]}], ",", " ", "\n", "\t", 
    RowBox[{"{", 
     RowBox[{"i", ",", " ", "1", ",", " ", "5"}], "}"}]}], "]"}], 
  ";"}]], "Code",
 CellLabel->
  "In[20764]:=",ExpressionUUID->"d1e2c6d5-9295-420f-9498-3927ef0f8727"],

