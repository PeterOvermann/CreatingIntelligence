Cell["Random sequence data", "Subsection",ExpressionUUID->"4d27fc5b-ff63-4dd1-9cd3-d01f4584a70b"],

Cell["A sequence of 1000 digits:", "Text",ExpressionUUID->"ad453c0d-aa19-4af7-92ec-65374d74dbbb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dataset", " ", "=", " ", 
   RowBox[{"RandomInteger", "[", " ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "10"}], "}"}], ",", " ", "1000"}], "]"}]}], 
