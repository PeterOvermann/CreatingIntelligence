Cell[CellGroupData[{

Cell["Reservoir Architecture", "Title",ExpressionUUID->"d073459d-127b-439c-b315-94de6963b699"],

Cell["Bigram encoder and double-delay reservoir", "Subtitle",ExpressionUUID->"74e7b6e8-0439-46d3-8fb5-ca078b2a5326"],

Cell["\<\
This model represents a simple recurrent reservoir fed by a bigram encoder. A \
readout node (predictive hetero-associative memory component) learns to \
predict the next input based on the current input and the state of the \
reservoir.\
\>", "Text",ExpressionUUID->"86cc569a-be37-4aff-8a57-73ac76739a7f"],

Cell["This architecture functions as a basic sequence memory.", "Text",ExpressionUUID->"d18ea87b-4212-4d60-8ef0-3772c57842e7"],

