}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"dataset", " ", "=", " ", 
   RowBox[{"RandomChoice", "[", " ", 
    RowBox[{"chars", ",", " ", "2000"}], "]"}]}], ";"}]], "Code",
 CellLabel->"In[35]:=",ExpressionUUID->"e806d413-0c92-4cc7-9b23-4fc824eb8759"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Analyze prediction score", "Subsection",ExpressionUUID->"43b23ddc-096d-451f-92cd-c27b2a89dbd7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Do", "[", " ", "\n", "\t", 
   RowBox[{
    RowBox[{
     RowBox[{"predictions", " ", "=", " ", 
      RowBox[{"c", " ", "/@", " ", "dataset"}]}], ";", " ", "\n", "\t", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<    iteration = \>\"", ",", " ", "i", ",", " ", "\n", 
       "\t", "\"\<, prediction score = \>\"", ",", " ", 
       RowBox[{"N", "[", 
        RowBox[{"Mean", "@", 
         RowBox[{"Boole", "@", 
          RowBox[{"MapThread", "[", 
           RowBox[{"SameQ", ",", " ", "\n", "\t\t", 
            RowBox[{"{", 
             RowBox[{"dataset", ",", " ", 
              RowBox[{"RotateRight", "[", "predictions", "]"}]}], "}"}]}], 
           "]"}]}]}], "]"}]}], "]"}]}], ",", " ", "\n", "\t", 
    RowBox[{"{", 
     RowBox[{"i", ",", " ", "1", ",", " ", "10"}], "}"}]}], "]"}], 
  ";"}]], "Code",
 CellLabel->"In[36]:=",ExpressionUUID->"d1e2c6d5-9295-420f-9498-3927ef0f8727"],

