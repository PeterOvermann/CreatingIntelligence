Cell[CellGroupData[{

Cell["Synthetic training data", "Subsection",ExpressionUUID->"4d27fc5b-ff63-4dd1-9cd3-d01f4584a70b"],

Cell["Generate a 2000 character random string.", "Text",ExpressionUUID->"ad453c0d-aa19-4af7-92ec-65374d74dbbb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"chars", " ", "=", " ", 
  RowBox[{"CharacterRange", "[", 
   RowBox[{"\"\<A\>\"", ",", " ", "\"\<Z\>\""}], "]"}]}]], "Code",
 CellLabel->"In[34]:=",ExpressionUUID->"32ac3f74-e565-4d04-9999-879741f3ac4c"],

