Cell[CellGroupData[{

Cell["Hetero-associative memory", "Section",ExpressionUUID->"07b532b8-3551-445b-ae77-9ca9a4c9ba6f"],

Cell["\<\
Here is a basic hetero-associative memory circuit, taking two inputs and \
generating one output:\
\>", "Text",ExpressionUUID->"1cec135a-d6e5-40ed-a299-ee61a35bd6cd"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dataflow", "[", 
  RowBox[{
   RowBox[{"{", " ", "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"input", "[", "]"}], " ", "[", "11", "]"}], " ", "[", "]"}], ",",
      " ", "\n", "\t", 
