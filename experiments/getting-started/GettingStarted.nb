Cell[CellGroupData[{

Cell["Supervised Learning with Heteroassociations", "Section",ExpressionUUID->"1d99a2fe-40d2-4fca-8aa6-88f9781f2ca8"],

Cell["\<\
The \[OpenCurlyDoubleQuote]associator\[CloseCurlyDoubleQuote] node implements \
a basic hetero-associative memory for supervised learning applications. It \
stores associations of the form A->B, where A and B are typically sets from \
different spaces with different hyperparameters.\
\>", "Text",ExpressionUUID->"ca96f88b-55cc-4bce-a087-5ce23c164ef3"],

Cell["\<\
Heteroassociations may involve perceptual (SDR) or symbolic (SHR) data. \
\>", "Text",ExpressionUUID->"433fdc36-b458-416a-8830-6884a51d0251"],

Cell["\<\
This basic example demonstrates heteroassociations between symbolic \
representations. Note that the training signal (B) is the first argument of \
the associator node:\
\>", "Text",ExpressionUUID->"615bc8b4-0bdf-4416-ae30-842f7723eb54"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dataflow", "[", 
  RowBox[{
   RowBox[{"{", " ", "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"input", "[", "codec", "]"}], " ", "[", "11", "]"}], " ", "[", 
      "]"}], ",", " ", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"input", "[", "codec", "]"}], " ", "[", "21", "]"}], " ", "[", 
      "]"}], ",", " ", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"associator", "[", "]"}], " ", "[", "101", "]"}], " ", "[", 
      RowBox[{"21", ",", " ", "11"}], "]"}], ",", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"output", "[", "codec", "]"}], " ", "[", "]"}], " ", "[", 
      "101", "]"}], ",", "\n", "\t", 
     RowBox[{"11", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1000", ",", " ", "10"}], "}"}]}], ",", "\n", "\t", 
     RowBox[{"_", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1500", ",", " ", "15"}], "}"}]}]}], "\n", "\t", "}"}], ",", 
   " ", "240"}], "  ", "]"}]], "Code",
 CellLabel->
