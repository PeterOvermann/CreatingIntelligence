     RowBox[{"_", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1000", ",", " ", "5"}], "}"}]}], ",", "\n", "\t", 
     RowBox[{"\"\<multiplex\>\"", " ", "->", " ", "\"\<111\>\""}]}], "\n", 
    "\t", "}"}], ",", " ", "120"}], "]"}]], "Code",
