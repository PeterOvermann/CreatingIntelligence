Cell[CellGroupData[{

Cell["Predictive Associations", "Section",ExpressionUUID->"33004ff6-f873-4522-acd6-a86589579c6f"],

Cell["\<\
The \[OpenCurlyDoubleQuote]predictor\[CloseCurlyDoubleQuote] node is a \
hetero-associative memory component that predicts its next input based on the \
current input and a context. The context is typically a readout from a \
recurrent reservoir network.\
\>", "Text",ExpressionUUID->"2383b400-3a56-4c77-b741-ef4851a0aad4"],

Cell["\<\
Note that the token to be learned is given as the first argument of the node\
\[CloseCurlyQuote]s \[OpenCurlyDoubleQuote]receive\[CloseCurlyDoubleQuote] \
sequence (slot 11 in the example below).  The remaining arguments represent \
the context, which may be partitioned into multiple blocks.\
\>", "Text",ExpressionUUID->"18afb136-8661-4a3b-a35f-af6074e02b1b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dataflow", "[", 
  RowBox[{
   RowBox[{"{", " ", "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"input", "[", "codec", "]"}], " ", "[", "11", "]"}], " ", "[", 
      "]"}], ",", " ", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"input", "[", "codec", "]"}], " ", "[", "21", "]"}], " ", "[", 
      "]"}], ",", " ", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"predictor", "[", "]"}], " ", "[", "101", "]"}], " ", "[", 
      RowBox[{"11", ",", " ", "21"}], "]"}], ",", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"output", "[", "codec", "]"}], " ", "[", "]"}], " ", "[", 
      "101", "]"}], ",", "\n", "\t", 
     RowBox[{"_", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1000", ",", " ", "10"}], "}"}]}]}], "\n", "\t", "}"}], ",", 
   " ", "240"}], "  ", "]"}]], "Code",
