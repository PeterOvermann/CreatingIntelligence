Cell[CellGroupData[{

Cell["Auto-Associative Memory", "Section",ExpressionUUID->"01fa9b34-ffb2-4c48-988b-55e8e0f8ad1d"],

Cell["\<\
Auto-associative memory components can be configured with various update \
rules that govern how the memory\[CloseCurlyQuote]s input/output layer X is \
updated with the pattern Y retrieved from memory. This table outlines the \
most common methods:
\
\>", "Text",ExpressionUUID->"26c2ce2d-4387-443f-8486-887293b6815b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tablerule", "[", "grid_", "]"}], " ", ":=", "  ", 
  RowBox[{"TextGrid", "[", 
   RowBox[{"grid", ",", " ", 
    RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
    RowBox[{"Dividers", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{"All", ",", "All"}], "}"}]}], ",", "\n", 
    RowBox[{"FrameStyle", " ", "->", " ", 
     RowBox[{"Directive", "[", 
      RowBox[{
       RowBox[{"Circuit`color", "[", "3", "]"}], ",", " ", "Medium"}], 
      "]"}]}], ",", "  ", "\n", 
    RowBox[{"ItemSize", "->", " ", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"6", ",", "15", ",", "15"}], "}"}], "}"}]}], ",", " ", 
    RowBox[{"Spacings", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1.7"}], "}"}]}], ",", " ", 
    RowBox[{"Alignment", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Center", ",", " ", "Center", ",", " ", "Center"}], "}"}], ",",
        " ", "Center"}], "}"}]}]}], "\n", "]"}]}]], "Code",
 CellLabel->
  "In[242]:=",ExpressionUUID->"6ea3ac29-57d8-4af2-a2d6-c4eb36271750"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tablerule", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<\[FilledDownTriangle]\>\"", ",", " ", "\"\<replacement\>\"",
       ",", " ", "\"\<X \[LeftArrow] Y\>\""}], "}"}], ",", "\n", 
    RowBox[{"{", 
     RowBox[{"\"\<\[FilledUpTriangle]\>\"", ",", " ", "\"\<residual\>\"", ",",
       " ", "\"\<X \[LeftArrow] X \\\\ Y\>\""}], "}"}], ",", "\n", 
    RowBox[{"{", 
     RowBox[{"\"\<\[EmptyDownTriangle]\>\"", ",", " ", "\"\<complement\>\"", ",",
       " ", "\"\<X \[LeftArrow] Y \\\\ X \>\""}], "}"}], ",", "\n", 
    RowBox[{"{", 
     RowBox[{"\"\<\[EmptyUpTriangle]\>\"", ",", " ", "\"\<difference\>\"", ",",
       " ", "\"\<X \[LeftArrow] X \[EmptyUpTriangle] Y\>\""}], "}"}], ",", 
    "\n", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Intersection]\>\"", ",", " ", "\"\<coincidence\>\"", ",", 
      " ", "\"\<X \[LeftArrow] X \[Intersection] Y\>\""}], "}"}], ",", "\n", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Union]\>\"", ",", " ", "\"\<augmentation\>\"", ",", 
      " ", "\"\<X \[LeftArrow] X \[Union] Y\>\""}], "}"}]}], "\n", "\n", 
   "}"}], "]"}]], "Code",
 CellLabel->
  "In[243]:=",ExpressionUUID->"62572015-5bd7-42ca-b4e7-faac2311894e"],

