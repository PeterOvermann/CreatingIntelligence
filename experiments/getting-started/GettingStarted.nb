Cell[BoxData[
 RowBox[{"table3", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<X\>\"", ",", "\"\<veto\>\"", 
      ",", "\"\<clears all paths if any X path is non-empty\>\""}], "}"}], ",",
     " ", "\n", 
    RowBox[{"{", 
     RowBox[{"\"\<*\>\"", ",", " ", "\"\<mandatory\>\"", 
      ",", "\"\<clears all paths if any * path is empty\>\""}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"\"\<!\>\"", ",", " ", "\"\<priority\>\"", 
      ",", "\"\<clears all non-! paths if any ! path is non-empty\>\""}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"\"\<&\>\"", ",", " ", "\"\<dependency\>\"", ",", 
      " ", "\"\<clears & paths if any non-& path is empty (AND)\>\""}], "}"}],
     ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"\"\<|\>\"", ",", " ", "\"\<fallback\>\"", ",", 
      " ", "\"\<clears | paths if any non-| path is non-empty (NOR)\>\""}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"\"\<=\>\"", ",", " ", "\"\<barrier\>\"", ",", 
      " ", "\"\<clears = paths if any = path is empty\>\""}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"\"\<K\>\"", ",", " ", "\"\<kWTA\>\"", ",", 
      " ", "\"\<top-k excitatory (positive) signals\>\""}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"\"\<k\>\"", ",", " ", "\"\<kWTA\>\"", ",", 
      " ", "\"\<top-k signals (total saliency)\>\""}], "}"}]}], "}"}], 
  "]"}]], "Code",
