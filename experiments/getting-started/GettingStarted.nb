Cell["\<\
Generative behavior emerges if we feed the output of an auto-associative \
memory back into its input. This example uses the \
\[OpenCurlyDoubleQuote]complement\[CloseCurlyDoubleQuote] update rule:\
\>", "Text",ExpressionUUID->"0948ec5c-8860-459e-9376-913c533e9829"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dataflow", "[", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"input", "[", "codec", "]"}], " ", "[", "11", "]"}], " ", "[", 
      "]"}], ",", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"auto", "[", 
        RowBox[{"complement", ",", 
         RowBox[{"\"\<L\>\"", "->", 
          RowBox[{"{", 
           RowBox[{"10", ",", "100"}], "}"}]}]}], "]"}], " ", "[", "21", 
       "]"}], " ", "[", 
      RowBox[{"{", 
       RowBox[{"11", ",", "21"}], "}"}], "]"}], ",", " ", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"output", "[", "codec", "]"}], " ", "[", "]"}], " ", "[", "21",
       "]"}], ",", "\n", "\t", 
     RowBox[{"_", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1000", ",", " ", "10"}], "}"}]}]}], "\n", "\t", "}"}], ",", 
   " ", "200"}], "]"}]], "Code",
 CellLabel->
