Cell[CellGroupData[{

Cell["Heteroencoding", "Section",ExpressionUUID->"2d20a796-7a3c-473d-a912-dcd25c1a1dce"],

Cell["\<\
A heteroencoder is a hetero-associative memory component that clusters sparse \
distributed representations (SDRs) based on their similarity. It creates a \
random sparse holographic representation (SHR) for each cluster identified in \
the input data.\
\>", "Text",ExpressionUUID->"41f31a27-9d8a-48dc-9103-acef1fb2f04c"],

