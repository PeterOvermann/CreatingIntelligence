Cell["\<\
In the dataflow description, each circuit component is declared with three \
blocks of arguments:\
\>", "Text",ExpressionUUID->"0e302caa-f1cb-4c6e-833f-c631bbf5b497"],

Cell[TextData[{
 "         ",
 StyleBox["component[arguments, options] [send] [receive]",
  FontFamily->"Source Code Pro",
  FontWeight->"Regular"]
}], "Text",
 FontSize->12,ExpressionUUID->"337340d0-2350-4de0-8647-db0af51d47fa"],

Cell["\<\
Connections are indicated with slot numbers, which can be choosen \
arbitrarily. Hyperparameters are assigned to slots. In the above example, a \
dimension N = 1000 and a set population P = 10 are applied to all slots.

This setup simply echoes its input:\
\>", "Text",ExpressionUUID->"9a0f8562-2f15-4904-999d-5924785ac637"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"test", "[", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5"}], "}"}], "]"}], "[", 
  
  RowBox[{"{", 
   RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5"}], "}"}], 
  "]"}]], "Code",
 CellLabel->"In[25]:=",ExpressionUUID->"5245656a-10d0-46f0-a6c4-638194d0cbb8"],

