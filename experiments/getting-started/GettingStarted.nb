 RowBox[{
  RowBox[{
   RowBox[{"date", "[", "_", "]"}], " ", ":=", " ", 
   RowBox[{"DateString", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<Day\>\"", ",", " ", "\"\< \>\"", ",", 
      " ", "\"\<MonthNameShort\>\"", ",", "\"\< \>\"", ",", 
      " ", "\"\<Year\>\""}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"dataflow", "[", 
