      RowBox[{
       RowBox[{"output", "[", "codec", "]"}], "[", "]"}], "[", "11", "]"}], ",",
      " ", "\n", "\t", 
     RowBox[{"_", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1000", ",", "10"}], "}"}]}]}], "\n", "\t", "}"}], ",", " ", 
