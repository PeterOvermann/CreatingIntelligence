Cell["\<\
The left-hand side of a heteroassociation A -> B can be partitioned into \
blocks. Here we set up a dataflow with a bipartite input. The pattern \
matching threshold T is configured to be greater than the population of a \
single partition: \
\>", "Text",ExpressionUUID->"856b6661-c990-4341-8725-45a22fc35a9b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dataflow", "[", 
  RowBox[{
   RowBox[{"{", " ", "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"input", "[", "codec", "]"}], " ", "[", "11", "]"}], " ", "[", 
      "]"}], ",", " ", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"input", "[", "codec", "]"}], " ", "[", "12", "]"}], " ", "[", 
      "]"}], ",", " ", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"input", "[", "codec", "]"}], " ", "[", "21", "]"}], " ", "[", 
      "]"}], ",", " ", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"associator", "[", 
        RowBox[{"\"\<T\>\"", "->", "12"}], "]"}], " ", "[", "101", "]"}], " ",
       "[", 
      RowBox[{"21", ",", " ", "11", ",", " ", "12"}], "]"}], ",", "\n", "\t", 
     
     RowBox[{
      RowBox[{
       RowBox[{"output", "[", "codec", "]"}], " ", "[", "]"}], " ", "[", 
      "101", "]"}], ",", "\n", "\t", 
     RowBox[{"_", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1000", ",", " ", "10"}], "}"}]}]}], "\n", "\t", "}"}], ",", 
   " ", "240"}], "  ", "]"}]], "Code",
 CellLabel->
  "In[318]:=",ExpressionUUID->"2e432e3a-7a4b-4072-ab93-6abc27d574d9"],

