    RowBox[{"{", 
     RowBox[{"\"\<R\>\"", ",", " ", "\"\<rate limiting\>\"", 
      ",", "\"\<limits the population to the path's hyperparameter\>\""}], 
     "}"}], ",", " ", "\n", 
    RowBox[{"{", 
     RowBox[{"\"\<T\>\"", ",", " ", "\"\<threshold\>\"", 
      ",", "\"\<clears data below hyperparameter population\>\""}], "}"}], ",",
     "\n", 
    RowBox[{"{", 
     RowBox[{"\"\<~\>\"", ",", " ", "\"\<noise\>\"", 
