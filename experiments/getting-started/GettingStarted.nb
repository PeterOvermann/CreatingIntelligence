Cell[BoxData[
 RowBox[{"dataflow", "[", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"input", "[", "codec", "]"}], " ", "[", "11", "]"}], " ", "[", 
      "]"}], ",", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"auto", "[", 
        RowBox[{"complement", ",", 
         RowBox[{"\"\<L\>\"", "->", 
          RowBox[{"{", 
           RowBox[{"10", ",", "100"}], "}"}]}]}], "]"}], " ", "[", "21", 
       "]"}], " ", "[", "11", "]"}], ",", " ", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"output", "[", "codec", "]"}], " ", "[", "]"}], " ", "[", "21",
       "]"}], ",", "\n", "\t", 
     RowBox[{"_", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1000", ",", " ", "10"}], "}"}]}]}], "\n", "\t", "}"}], ",", 
   " ", "200"}], "]"}]], "Code",
 CellLabel->
  "In[289]:=",ExpressionUUID->"9de1a904-bafa-434f-a7d3-269ccf7e1e83"],

