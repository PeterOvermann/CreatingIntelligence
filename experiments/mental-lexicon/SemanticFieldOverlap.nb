Cell["Semantic Field Overlap", "Title",ExpressionUUID->"d073459d-127b-439c-b315-94de6963b699"],

Cell[" KWTA applied to word activation maps.", "Subtitle",ExpressionUUID->"74e7b6e8-0439-46d3-8fb5-ca078b2a5326"],

Cell["\<\
Store a dataset of 1.8M word associations (e.g. \[OpenCurlyDoubleQuote]ship\
\[CloseCurlyDoubleQuote]->\[CloseCurlyDoubleQuote]sail\[CloseCurlyDoubleQuote]\
) in hetero-associative memory. Retrieve activation maps for two input tokens \
and compute their overlap using kWTA.\
\>", "Text",ExpressionUUID->"86cc569a-be37-4aff-8a57-73ac76739a7f"],

