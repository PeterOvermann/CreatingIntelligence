Cell[CellGroupData[{

Cell["Adjusted Rand Index", "Subsection",ExpressionUUID->"d7d929c8-dc66-4533-83a6-5f21b41875e7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ARI", "[", 
   RowBox[{"A_List", ",", " ", "B_List", ",", " ", "dim_Integer"}], "]"}], 
  " ", ":=", " ", "\n", 
  RowBox[{"N", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Length", "[", 
       RowBox[{"Intersection", "[", 
        RowBox[{"A", ",", "B"}], "]"}], "]"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"Length", "[", "A", "]"}], "*", 
       RowBox[{
        RowBox[{"Length", "[", "B", "]"}], " ", "/", " ", "dim"}]}]}], " ", 
     ")"}], " ", "/", "\[IndentingNewLine]", "     ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Min", "[", 
       RowBox[{
        RowBox[{"Length", "[", "A", "]"}], ",", " ", 
        RowBox[{"Length", "[", "B", "]"}]}], "]"}], " ", "-", "  ", 
      RowBox[{
       RowBox[{"Length", "[", "A", "]"}], "*", 
       RowBox[{
        RowBox[{"Length", "[", "B", "]"}], " ", "/", " ", "dim"}]}]}], 
     ")"}]}], "]"}]}]], "Code",
 CellLabel->"In[38]:=",ExpressionUUID->"2f906e5f-55a8-498d-b1ac-9a5796c03e0e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"similarity", "[", 
   RowBox[{"x_", ",", " ", "y_"}], "]"}], " ", ":=", " ", 
  RowBox[{"ARI", "[", " ", 
   RowBox[{
    RowBox[{"c", "[", 
     RowBox[{"x", ",", " ", "Null"}], "]"}], ",", " ", 
    RowBox[{"c", "[", 
     RowBox[{"y", ",", " ", "Null"}], "]"}], ",", " ", "n"}], "]"}]}]], "Code",\

 CellLabel->"In[39]:=",ExpressionUUID->"5a15a173-e7c5-4636-afa9-6e0ae859ec01"]
