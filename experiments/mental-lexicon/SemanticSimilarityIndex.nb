Cell[CellGroupData[{

Cell["Similarity Matrix", "Subsection",ExpressionUUID->"594d33f9-a243-460e-8e37-f5805e2e9a00"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SimilarityMatrix", "[", " ", "items_List", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", " ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"simtable", ",", " ", "xTicks", ",", " ", "yTicks"}], "}"}], ",",
     "\n", "\t", "\n", "\t", 
    RowBox[{
     RowBox[{"simtable", " ", "=", " ", 
      RowBox[{"Outer", "[", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Round", "[", 
          RowBox[{
           RowBox[{"similarity", "[", "##", "]"}], ",", " ", "0.001"}], "]"}],
          "&"}], ",", " ", "items", ",", " ", "items"}], "]"}]}], ";", " ", 
     "\n", "\t", 
     RowBox[{"xTicks", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Rotate", "[", 
           RowBox[{
            RowBox[{"items", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", 
            RowBox[{"90", " ", "Degree"}]}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0"}], "}"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "items", "]"}]}], "}"}]}], "]"}]}], ";", 
     "\n", "\t", 
     RowBox[{"yTicks", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"items", "[", 
           RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0"}], "}"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "items", "]"}]}], "}"}]}], "]"}]}], ";", 
     "\n", "\t", "\n", "\t", 
     RowBox[{"MatrixPlot", "[", 
      RowBox[{"simtable", ",", " ", "\n", "\t\t", 
       RowBox[{"FrameTicks", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"yTicks", ",", " ", "None"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"None", ",", " ", "xTicks"}], "}"}]}], "}"}]}], ",", 
       "\[IndentingNewLine]", "\t\t", 
       RowBox[{"FrameStyle", " ", "->", " ", 
        RowBox[{"Opacity", "[", "0", "]"}]}], ",", "\n", "\t\t", 
       RowBox[{"FrameTicksStyle", " ", "->", " ", 
        RowBox[{"Directive", "[", 
         RowBox[{
          RowBox[{"Opacity", "[", "1", "]"}], ",", "\n", "\t\t", 
          RowBox[{"FontFamily", " ", "->", " ", "\"\<Inter Variable\>\""}], ",",
           "\n", "\t\t", 
          RowBox[{"FontSize", "->", "12"}]}], "]"}]}]}], "]"}]}]}], "\n", 
   "\t", "]"}]}]], "Code",
 CellLabel->"In[47]:=",ExpressionUUID->"2aebaa74-52bd-4ba5-9151-8f7e8cb19a00"],

