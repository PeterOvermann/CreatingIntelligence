Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Plug", "-", 
    RowBox[{"in", " ", "mechanism", " ", "for", " ", "error", " ", 
     RowBox[{"messages", "."}]}]}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "ident"}], "     ", "=", 
     " ", "\"\<`1`: Inputs must match outputs.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "identdim"}], "  ", "=", 
     " ", "\"\<`1`: Input and output dimensions must be identical.\>\""}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "totaldim"}], "  ", "=", 
     " ", "\"\<`1`: Total input and output dimensions must match.\>\""}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "dupedge"}], "   ", "=", 
     " ", "\"\<Duplicate edge specification `1`.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "sequence"}], "  ", "=", 
     " ", "\"\<`1`: Function arguments do not match input nodes.\>\""}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "routing"}], "   ", "=", 
     " ", "\"\<Invalid routing specification `1`.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "dimbundle"}], " ", "=", 
     " ", "\"\<`1`: Cannot bundle sets with different dimensions.\>\""}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "dimfirst"}], "  ", "=", 
     " ", "\"\<`1`: Output must match first input slot.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "input"}], "     ", "=", 
     " ", "\"\<No input slots allowed in `1`.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "oneinp"}], "    ", "=", 
     " ", "\"\<Expecting one input slot in `1`.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "arginp"}], "    ", "=", 
     " ", "\"\<`1`: Missing input.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "output"}], "    ", "=", 
     " ", "\"\<No output slots allowed in `1`.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "oneout"}], "    ", "=", 
     " ", "\"\<`1`: Expecting one output slot.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "argout"}], "    ", "=", 
     " ", "\"\<`1`: Missing output.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "multinp"}], "   ", "=", 
     " ", "\"\<`1`: Expecting multiple input slots.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "integer"}], "   ", "=", 
     " ", "\"\<Invalid data: `1`\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "extfunc"}], "   ", "=", 
     " ", "\"\<`1`: Invalid external function specification.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "embedded"}], "  ", "=", 
     " ", "\"\<`1`: Hyperparameters of embedded circuit do not match.\>\""}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "noparam"}], "   ", "=", 
     " ", "\"\<No hyperparameters specified for slot `1`.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "category"}], "  ", "=", 
     " ", "\"\<Category encoder requires dimension `1` or greater.\>\""}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "encoder"}], "   ", "=", 
     " ", "\"\<`1` cannot be used as a decoder.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "decoder"}], "   ", "=", 
     " ", "\"\<`1` cannot be used as an encoder.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "regress"}], "   ", "=", 
     " ", "\"\<Regression: output should match `1`.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Circuit", "::", "multiplex"}], " ", "=", 
     " ", "\"\<Malformed multiplex specification `1`.\>\""}], 
    ";"}]}]}]], "Code",
